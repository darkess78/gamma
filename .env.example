SHANA_LLM_PROVIDER=mock
SHANA_LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
SHANA_STT_PROVIDER=local
SHANA_STT_MODEL=base.en
SHANA_STT_DEVICE=cpu
SHANA_STT_COMPUTE_TYPE=int8
SHANA_TTS_PROVIDER=stub
SHANA_TTS_PROFILE=
SHANA_TTS_MODEL=gpt-4o-mini-tts
SHANA_TTS_VOICE=alloy
SHANA_TTS_FORMAT=wav
SHANA_PIPER_EXE=piper
SHANA_PIPER_MODEL_PATH=
SHANA_PIPER_CONFIG_PATH=
SHANA_PIPER_SPEAKER_ID=
# Keep RVC disabled for normal realtime use; enable it only for slower post-process conversion.
SHANA_RVC_ENABLED=false
# Optional when the repo is in an expected location such as ../RVC/Retrieval-based-Voice-Conversion-WebUI-main
SHANA_RVC_PYTHON=
SHANA_RVC_PROJECT_ROOT=
# Required when RVC is enabled.
SHANA_RVC_MODEL_NAME=
# Optional when Gamma can find a matching .index under the RVC checkout.
SHANA_RVC_INDEX_PATH=
SHANA_RVC_PITCH=0
SHANA_RVC_FORMANT=0.0
SHANA_RVC_F0_METHOD=fcpe
SHANA_RVC_INDEX_RATE=0.0
SHANA_RVC_FILTER_RADIUS=3
SHANA_RVC_RMS_MIX_RATE=0.0
SHANA_RVC_PROTECT=0.33
SHANA_RVC_RESAMPLE_SR=0
SHANA_RVC_DEVICE=
SHANA_GPT_SOVITS_ENDPOINT=
SHANA_GPT_SOVITS_REFERENCE_AUDIO=
SHANA_GPT_SOVITS_PROMPT_TEXT=
SHANA_GPT_SOVITS_PROMPT_LANG=en
SHANA_GPT_SOVITS_TEXT_LANG=en
SHANA_GPT_SOVITS_TIMEOUT_SECONDS=120
SHANA_GPT_SOVITS_EXTRA_JSON={}
SHANA_MEMORY_ENABLED=true
SHANA_MEMORY_WRITE_MODE=selective
SHANA_DATABASE_URL=sqlite:///./gamma.db
SHANA_AUDIO_OUTPUT_DIR=./data/audio
SHANA_LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
SHANA_LOCAL_LLM_MODEL=gpt-oss:20b
SHANA_LOCAL_LLM_TIMEOUT_SECONDS=120
SHANA_DASHBOARD_AUTH_ENABLED=false
SHANA_DASHBOARD_AUTH_USERNAME=
SHANA_DASHBOARD_AUTH_PASSWORD=
SHANA_DASHBOARD_SESSION_SECRET=
SHANA_DASHBOARD_COOKIE_SECURE=false
SHANA_API_AUTH_ENABLED=false
SHANA_API_BEARER_TOKEN=

# Local Ollama example:
# SHANA_LLM_PROVIDER=ollama
# SHANA_LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
# SHANA_LOCAL_LLM_MODEL=llama3.2:3b

# Mixed providers:
# SHANA_LLM_PROVIDER=ollama
# SHANA_STT_PROVIDER=openai
# SHANA_STT_MODEL=gpt-4o-mini-transcribe
# SHANA_TTS_PROVIDER=openai
# SHANA_TTS_MODEL=gpt-4o-mini-tts

# OpenAI voice example:
# OPENAI_API_KEY=your_key_here
# SHANA_LLM_PROVIDER=openai
# SHANA_LLM_MODEL=gpt-5.4-mini
# SHANA_STT_PROVIDER=openai
# SHANA_STT_MODEL=gpt-4o-mini-transcribe
# SHANA_TTS_PROVIDER=openai
# SHANA_TTS_MODEL=gpt-4o-mini-tts
# Alternate OpenAI models:
# SHANA_LLM_MODEL=gpt-5.4
# SHANA_LLM_MODEL=gpt-5.4-nano
# SHANA_LLM_MODEL=gpt-4.1
# SHANA_STT_MODEL=gpt-4o-transcribe
# SHANA_STT_MODEL=gpt-4o-transcribe-diarize
# SHANA_STT_MODEL=whisper-1
# SHANA_TTS_MODEL=tts-1
# SHANA_TTS_MODEL=tts-1-hd

# Fully local voice example:
# SHANA_LLM_PROVIDER=ollama
# SHANA_LOCAL_LLM_MODEL=gpt-oss:20b
# SHANA_STT_PROVIDER=local
# SHANA_STT_MODEL=base.en
# SHANA_TTS_PROVIDER=piper
# SHANA_PIPER_EXE=piper
# SHANA_PIPER_MODEL_PATH=./data/piper/en_US-lessac-medium.onnx
# SHANA_PIPER_CONFIG_PATH=./data/piper/en_US-lessac-medium.onnx.json
# Keep this off for normal low-latency conversations.
# SHANA_RVC_ENABLED=true
# SHANA_RVC_PROJECT_ROOT=../RVC/Retrieval-based-Voice-Conversion-WebUI-main
# SHANA_RVC_PYTHON=../RVC/.venv/bin/python
# SHANA_RVC_MODEL_NAME=HenyaTheGeniusV2.pth
# SHANA_RVC_INDEX_PATH=
# SHANA_RVC_FORMANT=0.15

# GPT-SoVITS custom voice example:
# SHANA_LLM_PROVIDER=ollama
# SHANA_STT_PROVIDER=local
# SHANA_STT_MODEL=base.en
# SHANA_TTS_PROVIDER=local
# SHANA_GPT_SOVITS_ENDPOINT=http://127.0.0.1:9880/tts
