[Unit]
Description=Gamma Dashboard
After=network-online.target gamma-shana.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/gamma
EnvironmentFile=%h/gamma/.env
ExecStart=%h/gamma/.venv/bin/python -m uvicorn gamma.dashboard.main:app --host 0.0.0.0 --port 8001 --no-access-log
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
